{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/learn/:slug", "destination": "/seo-pages/:slug" }
  ],
  "redirects": [
    { "source": "/learn/", "destination": "/learn", "permanent": true },
    { "source": "/tools/wallet-selector", "destination": "/tools/bitcoin-wallet-selector", "permanent": false },
    { "source": "/tools/quiz", "destination": "/tools/knowledge-quiz", "permanent": false },
    { "source": "/tools/stack-the-sats", "destination": "/tools/stack-the-sats-calculator", "permanent": false },
    { "source": "/tools/roadmap", "destination": "/tools/bitcoin-roadmap", "permanent": false },
    { "source": "/tools/news-decoder", "destination": "/tools/bitcoin-news-decoder", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/seo-pages/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ]
}
